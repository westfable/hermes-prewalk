@@ -0,0 +1,183 @@
+"""Tests for the /prewalk slash command registration and handler.
+
+Verifies:
+1. Command is registered in COMMAND_REGISTRY with correct fields
+2. /pw alias resolves correctly
+3. Handler method exists on CLICommandsMixin
+4. cli.py has dispatch, init, and auto-swap integration points
+5. Flag parsing (--no-pause, --into MODEL, --max-todos N) works correctly
+6. One-completed-task semantics present in the frontier prompt
+"""
+
+import re
+
+import pytest
+
+
+class TestPrewalkCommandDef:
+    """Test the CommandDef registration for /prewalk."""
+
+    def test_prewalk_in_registry(self):
+        from hermes_cli.commands import COMMAND_REGISTRY
+        names = [c.name for c in COMMAND_REGISTRY]
+        assert "prewalk" in names
+
+    def test_prewalk_has_pw_alias(self):
+        from hermes_cli.commands import COMMAND_REGISTRY
+        prewalk = next(c for c in COMMAND_REGISTRY if c.name == "prewalk")
+        assert "pw" in prewalk.aliases
+
+    def test_prewalk_in_session_category(self):
+        from hermes_cli.commands import COMMAND_REGISTRY
+        prewalk = next(c for c in COMMAND_REGISTRY if c.name == "prewalk")
+        assert prewalk.category == "Session"
+
+    def test_prewalk_args_hint(self):
+        from hermes_cli.commands import COMMAND_REGISTRY
+        prewalk = next(c for c in COMMAND_REGISTRY if c.name == "prewalk")
+        assert "--no-pause" in prewalk.args_hint
+        assert "--into" in prewalk.args_hint
+        assert "--max-todos" in prewalk.args_hint
+
+    def test_pw_alias_resolves(self):
+        from hermes_cli.commands import resolve_command
+        cmd = resolve_command("pw")
+        assert cmd is not None
+        assert cmd.name == "prewalk"
+
+    def test_prewalk_in_commands_dict(self):
+        from hermes_cli.commands import COMMANDS
+        assert "/prewalk" in COMMANDS
+        assert "/pw" in COMMANDS
+
+
+class TestPrewalkHandler:
+    """Test the handler method exists and flag parsing works."""
+
+    def test_handler_exists(self):
+        from hermes_cli.cli_commands_mixin import CLICommandsMixin
+        assert hasattr(CLICommandsMixin, "_handle_prewalk_command")
+
+    def test_handler_is_callable(self):
+        from hermes_cli.cli_commands_mixin import CLICommandsMixin
+        import inspect
+        assert callable(getattr(CLICommandsMixin, "_handle_prewalk_command"))
+        sig = inspect.signature(CLICommandsMixin._handle_prewalk_command)
+        assert "cmd" in sig.parameters
+
+    def test_one_task_semantics_in_prompt(self):
+        """The frontier prompt must instruct one COMPLETED task, not one edit."""
+        from hermes_cli import cli_commands_mixin
+        src = open(cli_commands_mixin.__file__, encoding="utf-8").read()
+        assert "Complete Task #1" in src
+        assert "Do NOT start task #2" in src
+        assert "Mark task #1 as completed" in src
+
+    def test_pause_todo_in_prompt(self):
+        from hermes_cli import cli_commands_mixin
+        src = open(cli_commands_mixin.__file__, encoding="utf-8").read()
+        assert "PAUSE — Frontier handoff checkpoint" in src
+
+
+class TestPrewalkFlagParsing:
+    """Test the flag parsing logic (mirrors the handler's parsing)."""
+
+    @staticmethod
+    def _parse(cmd):
+        """Replicate the flag parsing from _handle_prewalk_command."""
+        parts = cmd.strip().split(maxsplit=1)
+        if len(parts) < 2 or not parts[1].strip():
+            return None, False, None, 12
+        args = parts[1].strip()
+        no_pause = "--no-pause" in args
+        executor_model = None
+        into_match = re.search(r"--into\s+(\S+)", args)
+        if into_match:
+            executor_model = into_match.group(1)
+            no_pause = True
+        max_todos = 12
+        mt_match = re.search(r"--max-todos\s+(\d+)", args)
+        if mt_match:
+            max_todos = int(mt_match.group(1))
+        task_desc = re.sub(r"--no-pause|--into\s+\S+|--max-todos\s+\d+", "", args).strip()
+        return task_desc, no_pause, executor_model, max_todos
+
+    def test_simple_task(self):
+        task, no_pause, executor, max_todos = self._parse("/prewalk Build a settings page")
+        assert task == "Build a settings page"
+        assert no_pause is False
+        assert executor is None
+        assert max_todos == 12
+
+    def test_no_pause_flag(self):
+        task, no_pause, executor, max_todos = self._parse("/prewalk Build a settings page --no-pause")
+        assert task == "Build a settings page"
+        assert no_pause is True
+        assert executor is None
+        assert max_todos == 12
+
+    def test_into_flag(self):
+        task, no_pause, executor, max_todos = self._parse("/prewalk --into cline-pass/qwen3.7-plus Build a page")
+        assert task == "Build a page"
+        assert no_pause is True  # --into implies auto-swap
+        assert executor == "cline-pass/qwen3.7-plus"
+        assert max_todos == 12
+
+    def test_into_with_local_model(self):
+        task, no_pause, executor, _ = self._parse("/prewalk Build a page --into lmstudio/gemma-4-26b")
+        assert task == "Build a page"
+        assert executor == "lmstudio/gemma-4-26b"
+
+    def test_max_todos_flag(self):
+        task, no_pause, executor, max_todos = self._parse("/prewalk --max-todos 5 Build a settings page")
+        assert task == "Build a settings page"
+        assert no_pause is False
+        assert max_todos == 5
+
+    def test_all_flags(self):
+        task, no_pause, executor, max_todos = self._parse(
+            "/prewalk --into m/x --max-todos 8 Build something")
+        assert task == "Build something"
+        assert no_pause is True
+        assert executor == "m/x"
+        assert max_todos == 8
+
+    def test_pw_alias_parsing(self):
+        task, no_pause, executor, max_todos = self._parse("/pw Quick task")
+        assert task == "Quick task"
+        assert no_pause is False
+        assert max_todos == 12
+
+    def test_no_args_returns_none(self):
+        task, no_pause, executor, max_todos = self._parse("/prewalk")
+        assert task is None
+
+
+class TestPrewalkCliIntegration:
+    """Verify cli.py has all three integration points in its source."""
+
+    def test_dispatch_in_process_command(self):
+        import cli
+        src = open(cli.__file__, encoding="utf-8").read()
+        assert 'canonical == "prewalk"' in src
+
+    def test_init_attributes(self):
+        import cli
+        src = open(cli.__file__, encoding="utf-8").read()
+        assert "_pending_prewalk_swap_after_turn = False" in src
+        assert "_pending_prewalk_executor_model" in src
+        assert "_pending_prewalk_restore_model" in src
+
+    def test_auto_swap_in_main_loop(self):
+        import cli
+        src = open(cli.__file__, encoding="utf-8").read()
+        assert "_pending_prewalk_swap_after_turn" in src
+        assert "cline-pass/deepseek-v4-flash" in src
+
+    def test_auto_swap_honors_named_executor(self):
+        """The swap block must use the recorded --into model, not a hardcoded one."""
+        import cli
+        src = open(cli.__file__, encoding="utf-8").read()
+        assert "_pending_prewalk_executor_model" in src
+        # continuation prompt must carry the anti-premature-done rule
+        assert "do not declare completion while unchecked" in src
