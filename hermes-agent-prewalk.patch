+    def _handle_prewalk_command(self, cmd: str) -> None:
+        """Handle /prewalk <task> — frontier model explores + plans + completes
+        exactly one task (edit + verification), then pauses for model switch.
+
+        Uses _pending_agent_seed to send the frontier prompt as the next agent
+        turn. For --no-pause / --into MODEL, sets up model-swap similar to /moa
+        so the executor model is auto-swapped after the frontier turn completes.
+
+        See ~/.hermes/skills/software-development/prewalk/SKILL.md for the
+        full workflow and prompt templates.
+        """
+        import re
+        from cli import _DIM, _RST, _cprint
+
+        default_executor = "cline-pass/deepseek-v4-flash"
+
+        parts = cmd.strip().split(maxsplit=1)
+        if len(parts) < 2 or not parts[1].strip():
+            _cprint(f"  {_DIM}Usage: /prewalk <task description> [--no-pause] [--into MODEL] [--max-todos N]{_RST}")
+            _cprint(f"  {_DIM}Example: /prewalk Build a settings page with tabbed sections{_RST}")
+            _cprint(f"  {_DIM}Alias: /pw{_RST}")
+            _cprint(f"  {_DIM}Manual mode (default): pauses after the first completed task for /model switch{_RST}")
+            _cprint(f"  {_DIM}--no-pause: auto-switches to {default_executor}{_RST}")
+            _cprint(f"  {_DIM}--into MODEL: auto-switches to the named executor (implies no pause){_RST}")
+            return
+
+        args = parts[1].strip()
+
+        # Parse flags
+        no_pause = "--no-pause" in args
+        executor_model = None
+        into_match = re.search(r'--into\s+(\S+)', args)
+        if into_match:
+            executor_model = into_match.group(1)
+            no_pause = True  # --into implies auto-swap
+        max_todos = 12  # default
+        mt_match = re.search(r'--max-todos\s+(\d+)', args)
+        if mt_match:
+            max_todos = int(mt_match.group(1))
+        # Clean flags from task description
+        task_desc = re.sub(r'--no-pause|--into\s+\S+|--max-todos\s+\d+', '', args).strip()
+
+        if not task_desc:
+            _cprint(f"  {_DIM}No task description found after flags.{_RST}")
+            _cprint(f"  {_DIM}Usage: /prewalk <task description> [--no-pause] [--into MODEL] [--max-todos N]{_RST}")
+            return
+
+        # Build the frontier prompt
+        preamble = (
+            "You are beginning a **prewalk** — a planning phase before a model switch.\n\n"
+            "Your job: explore the codebase, build a plan as a todo list, complete "
+            "exactly **one** task from that list (edit + verification), then "
+            "**STOP and pause**.\n\n"
+            "The executor model will inherit your context window — all your reads, your "
+            "todo list, and your one completed task. Everything you read now is context "
+            "the executor won't have to re-read, and your completed task is the "
+            "in-context example it will imitate. Make your exploration count, and make "
+            "your one task exemplary.\n\n"
+            "Budget: aim to finish exploration + plan + first task within roughly "
+            "7-10 turns. If you cannot land a confident first task in that budget, "
+            "stop and report why instead of grinding.\n\n"
+        )
+
+        instructions = (
+            f"## Task\n{task_desc}\n\n"
+            f"## Instructions\n\n"
+            f"### Step 1: Explore\n"
+            f"Read the codebase thoroughly:\n"
+            f"- package.json, config files (tsconfig, tailwind, vite/next config, etc.)\n"
+            f"- Existing components, pages, layouts, route structure\n"
+            f"- API routes, server actions, data models\n"
+            f"- Design system: colors, typography, spacing tokens, component library\n"
+            f"- Grep for patterns: state management, styling approach, auth setup\n"
+            f"- Check test setup and conventions\n\n"
+            f"**Do NOT search the web.** No web_search, no web_extract, no browser "
+            f"(except to reproduce a reported visual defect on a local dev server). "
+            f"This is a local-only exploration phase.\n\n"
+            f"### Step 2: Plan\n"
+            f"Create a todo list using the `todo` tool. Rules:\n"
+            f"- Maximum {max_todos} items\n"
+            f"- Each item is a COMPLETE task: specific file path + what to do + "
+            f"verification criterion — something that can be finished and checked "
+            f"off, not a fragment\n"
+            f"- Order: infrastructure → core functionality → polish → validation\n"
+            f"- Item #1 must be the foundational task (one file, one concept) — "
+            f"you will execute it yourself and it becomes the executor's example\n"
+            f"- Good: \"Create `src/app/settings/page.tsx` with tabbed layout. "
+            f"verify: page renders at /settings without errors\"\n"
+            f"- Bad: \"Build the settings page\"\n\n"
+            f"### Step 3: Complete Task #1 — and ONLY Task #1\n"
+            f"Execute the first todo item in full:\n"
+            f"1. Make the edit(s) that task #1 describes (typically one file, one concept)\n"
+            f"2. Run its verification criterion (e.g. `npx tsc --noEmit`, render check) "
+            f"and confirm it passes\n"
+            f"3. Mark task #1 as completed in the todo list\n\n"
+            f"Constraints:\n"
+            f"- Task #1 must match existing conventions exactly (imports, styling, "
+            f"patterns) — the executor will copy this pattern for every remaining item\n"
+            f"- Do NOT start task #2. Do NOT make edits beyond task #1's scope. "
+            f"One task, fully done, verified, checked off.\n"
+            f"- If task #1's verification fails, fix it before stopping — a broken "
+            f"first example poisons the executor. But stay within task #1's scope.\n\n"
+            f"### Step 4: Pause\n"
+            f"Add a final todo item (the structured pause task) and set it in progress:\n"
+            f"```\n"
+            f"⏸️ PAUSE — Frontier handoff checkpoint. Human: review the plan + task #1, "
+            f"optionally /compress, then /model <executor> and say \"continue\".\n"
+            f"```\n\n"
+            f"Then **STOP**. Present:\n"
+            f"- Summary of your approach (2-3 sentences)\n"
+            f"- The todo list state (task #1 checked off, PAUSE in progress, rest pending)\n"
+            f"- What task #1 was, how it was verified, and why it's the foundation\n\n"
+            f"Do NOT continue executing remaining items. Do NOT make additional edits.\n"
+        )
+
+        if no_pause:
+            _exec = executor_model or default_executor
+            instructions += (
+                f"\n--no-pause mode is active. After your first completed task, the "
+                f"system will auto-switch to the executor model ({_exec}). "
+                f"Your context will be inherited. The executor will continue from "
+                f"your todo list automatically.\n"
+            )
+
+        frontier_prompt = preamble + instructions
+
+        # For --no-pause / --into: set up model swap (similar to /moa)
+        if no_pause:
+            self._pending_prewalk_restore_model = {
+                "requested_provider": getattr(self, "requested_provider", None),
+                "provider": getattr(self, "provider", None),
+                "model": getattr(self, "model", None),
+                "api_key": getattr(self, "api_key", None),
+                "base_url": getattr(self, "base_url", None),
+                "api_mode": getattr(self, "api_mode", None),
+            }
+            self._pending_prewalk_executor_model = executor_model or default_executor
+            self._pending_prewalk_swap_after_turn = True
+            _cprint(f"  {_DIM}⚡ Auto mode: will switch to {executor_model or default_executor} "
+                    f"after the first completed task.{_RST}")
+        else:
+            _cprint(f"  {_DIM}🧭 Prewalk started. Frontier model will explore, plan, and "
+                    f"complete task #1 (edit + verification).{_RST}")
+            _cprint(f"  {_DIM}⏸️  Will pause after task #1 for your review.{_RST}")
+            _cprint(f"  {_DIM}   Then: /model <executor> to switch, and say 'continue'.{_RST}")
+
+        # Send the frontier prompt as the next agent turn
+        self._pending_agent_seed = frontier_prompt
+
